<Window x:Class="MarketData.Client.Wpf.Views.AddInstrumentWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MarketData.Client.Wpf.Views"
        xmlns:steps="clr-namespace:MarketData.Client.Wpf.ViewModels.AddInstrument.Steps"
        mc:Ignorable="d"
        Title="Add Instrument" Height="450" Width="650">

    <!--Wizard steps-->
    <Window.Resources>
        <DataTemplate DataType="{x:Type steps:NameInstrument}">
            <Grid Background="#999999" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                    Text="Instrument identifier" 
                               FontSize="16" 
                               Margin="5"/>

                <TextBox Grid.Row="0" Grid.Column="1" 
                         Text="{Binding InstrumentName, UpdateSourceTrigger=PropertyChanged}" 
                         Margin="5"/>

                <TextBlock Text="Selected model"
                           Grid.Row="1"
                           Grid.Column="0"
                           FontSize="16"
                           Margin="5"/>
                <ComboBox Grid.Row="1" Grid.Column="1"
                          ItemsSource="{Binding AvailableModels}"
                          SelectedItem="{Binding SelectedModel}"
                          Margin="5"/>

                <TextBlock Text="Initial price"
                           Grid.Row="2"
                           Grid.Column="0"
                           FontSize="16"
                           Margin="5"/>
                <TextBox Grid.Row="2" Grid.Column="1"
                         Text="{Binding InitialPrice, UpdateSourceTrigger=PropertyChanged}"
                         Margin="5"/>

                <TextBlock Text="Tick interval (ms)"
                           Grid.Row="3"
                           Grid.Column="0"
                           FontSize="16"
                           Margin="5"/>
                <TextBox Grid.Row="3" Grid.Column="1"
                         Text="{Binding TickIntervalMs, UpdateSourceTrigger=PropertyChanged}"
                         Margin="5"/>
            </Grid>
        </DataTemplate>
    </Window.Resources>


    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--Header-->
        <Grid Grid.ColumnSpan="2" Background="#111144" Height="50">
            <TextBlock Grid.ColumnSpan="2" 
                       Text="Add New Instrument" 
                       Foreground="#dddddd"
                       FontSize="18" 
                       FontWeight="Bold" 
                       Margin="10,0,0,0"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                   />
        </Grid>

        <!--Left panel-->
        <Grid Grid.Column="0" Grid.Row="1" Grid.RowSpan="2"
              Background="#444444">
            <StackPanel Margin="10">
                <TextBlock Text="Step 1: Select Instrument Type" 
                           Foreground="#dddddd" 
                           FontSize="12" 
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"/>
                <TextBlock Text="Step 2: Configure Details" 
                           Foreground="#888888" 
                           FontSize="12" 
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"/>
                <TextBlock Text="Step 3: Review and Confirm" 
                           Foreground="#888888" 
                           FontSize="12" 
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>

        <!--Content-->
        <Grid  Grid.Column="1" Grid.Row="1"
               Background="#999999">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <ContentControl 
                Margin="10"
                Content="{Binding CurrentStep}"/>

            <!--Validation-->
            <TextBlock Grid.Row="1" 
                       Text="{Binding CurrentStep.ValidationMessage}" 
                       Foreground="#440000" 
                       FontSize="16" 
                       FontWeight="Bold"
                       Margin="10,0,0,10"/>
        </Grid>

        <!--Navigation buttons-->
        <Border Grid.Row="2" Grid.Column="1" 
                Background="#444444" >
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        Margin="5">
                <Button Content="&lt; Previous" 
                        Width="80" 
                        Height="30" 
                        Margin="5"
                        Command="{Binding PreviousCommand}"/>
                <Button Content="{Binding NextCommandText, FallbackValue='Next &gt;'}" 
                        Width="80" 
                        Height="30" 
                        Margin="5"
                        Command="{Binding NextCommand}"/>
                <Button Content="Cancel" 
                        Width="80" 
                        Height="30" 
                        Margin="5"
                        Command="{Binding CancelCommand}"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
