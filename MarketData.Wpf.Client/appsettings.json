{
  "GrpcSettings": {
    "ServerUrl": "https://localhost:7264"
  },
  "CandleChart": {
    "CandlePrecision": 8,
    "CandleTimeFrame": -10, // see FancyCandles.TimeFrame enum for accepted values
    "LoadHistoryOnStartMinutes": 1440 // request history for the last N minutes on start
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Grpc": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "Logs/marketdata-client-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  }
}
