{
  "GrpcSettings": {
    "ServerUrl": "https://localhost:7264"
  },
  "OpenTelemetry": {
    "ServiceName": "MarketData.Wpf.Client",
    "ServiceVersion": "1.0.0",
    "OtlpEndpoint": "http://localhost:4317"
  },
  "CandleChart": {
    "CandlePrecision": 8,
    "CandleTimeFrame": -10, // see FancyCandles.TimeFrame enum for accepted values
    "LoadHistoryOnStartMinutes": 1440 // request history for the last N minutes on start
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.File", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Grpc": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "Logs/marketdata-client-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} [{Level:u3}] [{SourceContext}] [{Scope}] {Message:lj}{NewLine}{Exception}",
          "restrictedToMinimumLevel": "Debug"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341",
          "restrictedToMinimumLevel": "Verbose"
        }
      }
    ],
    "Enrich": [ 
      "FromLogContext", 
      "WithMachineName", 
      "WithThreadId",
      "WithProcessId",
      "WithProcessName",
      "WithSpan"
    ]
  }
}
